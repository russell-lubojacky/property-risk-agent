# ---------------------------------------------------------------------------
# Property Risk Agent — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is listed in .gitignore.
# ---------------------------------------------------------------------------

# -- Crime data (FBI UCR / Crime Data Explorer) ----------------------------
# Required for GET /api/crime
# Free key: https://api.data.gov/signup/
FBI_UCR_API_KEY=

# -- Future keys (uncomment when the relevant API routes are implemented) ---

# Anthropic Claude API — for AI-generated property summaries
# ANTHROPIC_API_KEY=

# Stripe — for subscription billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Google OAuth — for social login
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Database
# DATABASE_URL=

# Session signing secret (generate with: openssl rand -hex 32)
# SESSION_SECRET=
